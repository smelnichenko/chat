<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-1" author="chat-service">
        <comment>Create channels table</comment>
        <createTable tableName="channels">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="uuid">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(100)"/>
            <column name="system" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="encrypted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="current_key_version" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-2" author="chat-service">
        <comment>Create channel_members table</comment>
        <createTable tableName="channel_members">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="channel_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_channel_members_channel" references="channels(id)" deleteCascade="true"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="joined_at" type="timestamp" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="last_read_at" type="timestamp" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="channel_members" columnNames="channel_id, user_id" constraintName="uq_channel_members"/>
        <createIndex tableName="channel_members" indexName="idx_channel_members_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="001-3" author="chat-service">
        <comment>Create user_keys table for E2E encryption identity key pairs</comment>
        <createTable tableName="user_keys">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="public_key" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="encrypted_private_key" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="pbkdf2_salt" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="pbkdf2_iterations" type="int" defaultValueNumeric="600000">
                <constraints nullable="false"/>
            </column>
            <column name="key_version" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-4" author="chat-service">
        <comment>Create channel_key_bundles table for per-member encrypted channel keys</comment>
        <createTable tableName="channel_key_bundles">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="channel_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_channel_key_bundles_channel" references="channels(id)" deleteCascade="true"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="key_version" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="encrypted_channel_key" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="wrapper_public_key" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="channel_key_bundles" columnNames="channel_id, user_id, key_version" constraintName="uq_channel_key_bundle"/>
    </changeSet>

</databaseChangeLog>
